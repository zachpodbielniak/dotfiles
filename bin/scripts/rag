"""
rag - Local-first multi-corpus Retrieval-Augmented Generation knowledge base.

Features:
    - Multiple named corpora in a single local PostgreSQL + pgvector database.
    - Heading-aware parsing for .org, .md, .norg; paragraph chunking for text;
      regex boundary splitting for source code; Docling for PDFs/DOCX/PPTX/images
      (optional); structured splitting for YAML/JSON/CSV.
    - Incremental indexing with mtime+size fast path, SHA-256 on mismatch.
    - Hybrid search: pgvector cosine + PostgreSQL tsvector, combined via
      Reciprocal Rank Fusion.
    - stdio MCP server mode exposing retrieval + metadata tools.

Administration happens on the CLI (add/remove/update corpora, index, sync,
reindex). The MCP server only exposes read tools so clients cannot mutate
the index by accident.
"""


# ===== Distrobox container check =====================================
# Must execute BEFORE any heavy imports that are only available inside
# the `dev` distrobox. Pattern mirrors aipy, codepy, semantic_search.
import os
import sys
from subprocess import run

_ctr_id: str = os.environ.get("CONTAINER_ID", "")
_no_dbox_check: bool = os.environ.get("NO_DBOX_CHECK", "").lower() in ("1", "true")

if not _no_dbox_check and _ctr_id != "dev":
    _cmd: list[str] = ["distrobox", "enter", "dev", "--", *sys.argv]
    run(_cmd)
    sys.exit(0)


