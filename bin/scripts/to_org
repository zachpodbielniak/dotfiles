set -euo pipefail

SCRIPT_NAME="$(basename "${0}")"

usage () {
    cat <<EOF
${SCRIPT_NAME} - Convert input text to Emacs org-mode using AI

USAGE:
    ${SCRIPT_NAME} [OPTIONS]

DESCRIPTION:
    Reads text from stdin (or one or more input files) and converts it to
    well-formed Emacs org-mode using aipy. Optionally wraps the converted
    content under a named section heading at a chosen depth.

OPTIONS:
    -i, --input FILE      Input file to read. May be specified multiple times.
                          If omitted, reads from stdin.
    -o, --output FILE     Write the converted org content to FILE.
                          If omitted, writes to stdout.
    -s, --section TITLE   Wrap the converted content under a heading titled
                          TITLE at the depth specified by --depth.
    -d, --depth N         Starting org heading depth (1 = '*', 2 = '**', ...).
                          Defaults to 1. Any sub-headings produced by the AI
                          are nested below this level.
    -h, --help            Show this help message and exit.
    --license             Show the license (AGPLv3) and exit.

EXAMPLES:
    # Convert stdin to org and print to stdout
    cat notes.txt | ${SCRIPT_NAME}

    # Convert a single file under a section heading
    ${SCRIPT_NAME} -i notes.txt -s "Meeting Notes" -d 2

    # Combine several files into one org document
    ${SCRIPT_NAME} -i a.md -i b.md -i c.txt -s "Combined" -d 1 -o combined.org

    # Use as a filter in neovim/emacs
    :'<,'>!${SCRIPT_NAME} -s "Section" -d 3
EOF
}

show_license () {
    cat <<EOF
${SCRIPT_NAME} - Convert input text to Emacs org-mode using AI
Copyright (C) 2026  Zach Podbielniak

This program is free software: you can redistribute it and/or modify
it under the terms of the GNU Affero General Public License as published by
the Free Software Foundation, either version 3 of the License, or
(at your option) any later version.

This program is distributed in the hope that it will be useful,
but WITHOUT ANY WARRANTY; without even the implied warranty of
MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
GNU Affero General Public License for more details.

You should have received a copy of the GNU Affero General Public License
along with this program.  If not, see <https://www.gnu.org/licenses/>.
EOF
}

main () {
    local -a input_files=()
    local output_file=""
    local section=""
    local depth=1

    while [[ $# -gt 0 ]]
    do
        case "${1}" in
            -h|--help)
                usage
                exit 0
                ;;
            --license)
                show_license
                exit 0
                ;;
            -i|--input)
                if [[ $# -lt 2 ]]
                then
                    echo "Error: '${1}' requires a value." >&2
                    exit 1
                fi
                input_files+=("${2}")
                shift 2
                ;;
            -o|--output)
                if [[ $# -lt 2 ]]
                then
                    echo "Error: '${1}' requires a value." >&2
                    exit 1
                fi
                output_file="${2}"
                shift 2
                ;;
            -s|--section)
                if [[ $# -lt 2 ]]
                then
                    echo "Error: '${1}' requires a value." >&2
                    exit 1
                fi
                section="${2}"
                shift 2
                ;;
            -d|--depth)
                if [[ $# -lt 2 ]]
                then
                    echo "Error: '${1}' requires a value." >&2
                    exit 1
                fi
                depth="${2}"
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Error: Unknown option '${1}'" >&2
                echo "Use '${SCRIPT_NAME} --help' for usage information." >&2
                exit 1
                ;;
            *)
                echo "Error: Unexpected positional argument '${1}'" >&2
                echo "Use '${SCRIPT_NAME} --help' for usage information." >&2
                exit 1
                ;;
        esac
    done

    # Validate depth is a positive integer
    if ! [[ "${depth}" =~ ^[1-9][0-9]*$ ]]
    then
        echo "Error: --depth must be a positive integer (got '${depth}')." >&2
        exit 1
    fi

    # Build the heading prefix strings (e.g., '*', '**', '***')
    local section_stars
    section_stars="$(printf '%*s' "${depth}" '' | tr ' ' '*')"
    local child_depth=$((depth + 1))
    local child_stars
    child_stars="$(printf '%*s' "${child_depth}" '' | tr ' ' '*')"

    # Gather content from inputs or stdin
    local content=""
    if [[ ${#input_files[@]} -gt 0 ]]
    then
        local first=1
        local file
        for file in "${input_files[@]}"
        do
            if [[ ! -f "${file}" ]]
            then
                echo "Error: Input file '${file}' not found." >&2
                exit 1
            fi
            if [[ "${first}" -eq 1 ]]
            then
                content="$(cat -- "${file}")"
                first=0
            else
                content+=$'\n\n'"$(cat -- "${file}")"
            fi
        done
    else
        if [[ -t 0 ]]
        then
            echo "Error: No --input given and stdin is a terminal." >&2
            echo "Use '${SCRIPT_NAME} --help' for usage information." >&2
            exit 1
        fi
        content="$(cat)"
    fi

    if [[ -z "${content}" ]]
    then
        echo "Error: No content provided." >&2
        exit 1
    fi

    # Build the AI prompt. When --section is given, ask for a wrapping heading
    # at the requested depth; otherwise let the AI pick heading depths starting
    # at --depth.
    local prompt
    if [[ -n "${section}" ]]
    then
        prompt="Convert the following text into well-formed Emacs org-mode. \
Wrap the entire result under a single top-level heading exactly: \
'${section_stars} ${section}'. Any sub-sections you create must start at \
depth ${child_depth} (i.e., headings begin with '${child_stars}') and nest \
deeper from there. Preserve the original meaning and content exactly. Use \
proper org-mode syntax for headings, lists, code blocks (#+BEGIN_SRC / \
#+END_SRC), emphasis (/italic/, *bold*, =verbatim=, ~code~), and links \
([[url][desc]]). Do not add any commentary, preamble, explanations, or \
fenced markdown code wrappers. Output only the raw org-mode content."
    else
        prompt="Convert the following text into well-formed Emacs org-mode. \
Any top-level headings must start at depth ${depth} (i.e., headings begin \
with '${section_stars}') and nest deeper from there. Preserve the original \
meaning and content exactly. Use proper org-mode syntax for headings, \
lists, code blocks (#+BEGIN_SRC / #+END_SRC), emphasis (/italic/, *bold*, \
=verbatim=, ~code~), and links ([[url][desc]]). Do not add any commentary, \
preamble, explanations, or fenced markdown code wrappers. Output only the \
raw org-mode content."
    fi

    # Run aipy and emit to chosen destination
    if [[ -n "${output_file}" ]]
    then
        printf '%s' "${content}" | aipy --no-preserve --hide-model "${prompt}" > "${output_file}"
    else
        printf '%s' "${content}" | aipy --no-preserve --hide-model "${prompt}"
    fi
}

main "$@"
