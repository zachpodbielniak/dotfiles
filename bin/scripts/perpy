# === Helper functions ===

def api_request(endpoint: str, payload: dict, stream: bool = False, timeout: int = 120):
    """Make an authenticated request to the Perplexity API.

    Args:
        endpoint: API endpoint path (e.g. /chat/completions)
        payload: JSON request body
        stream: if True, return the raw response object for streaming
        timeout: request timeout in seconds

    Returns:
        parsed JSON dict for non-streaming, or the raw response object for streaming
    """
    url: str = f"{API_BASE}{endpoint}"
    headers: dict = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "Accept": "application/json",
    }

    data: bytes = json.dumps(payload).encode("utf-8")
    req: urllib.request.Request = urllib.request.Request(url, data=data, headers=headers, method="POST")

    if stream:
        return urllib.request.urlopen(req, timeout=timeout)
    else:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))


def get_model_limits(model: str) -> dict:
    """Get context and output token limits for a model."""
    if model in MODELS:
        return {"input": MODELS[model]["context"], "output": MODELS[model]["max_output"]}
    return {"input": 128_000, "output": 8_000}


def get_personality_prompt(personality_key: str) -> str:
    """Get the system prompt for a personality key, or treat as custom description."""
    if not personality_key:
        return ""
    key: str = personality_key.lower()
    if key in PERSONALITIES:
        return PERSONALITIES[key] + "\n\n"
    return f"You are {personality_key}.\n\n"


def get_emoji_prompt(emoji_mode: str) -> str:
    """Get the emoji instruction prompt for the given mode."""
    if not emoji_mode:
        return ""
    prompts: dict = {
        "light": "Feel free to use relevant emojis to enhance your response where appropriate.",
        "heavy": "Use emojis frequently throughout your response to make it more engaging and expressive. Include emojis to highlight key points, convey emotions, and make the content more visually appealing.",
    }
    return prompts.get(emoji_mode, prompts["light"]) + "\n\n"


def enhance_with_emojis(text: str, model: str = "sonar") -> str:
    """Enhance text with emojis using a secondary API call."""
    if not text or not text.strip():
        return text

    enhancement_prompt: str = (
        "Please add appropriate emojis to the following text to make it more engaging "
        "and expressive. Follow these guidelines:\n\n"
        "1. Add emojis that are relevant and enhance understanding\n"
        "2. Don't overdo it - use emojis strategically\n"
        "3. Maintain the original meaning and tone\n"
        "4. Place emojis at the BEGINNING of section headings, titles, and key points\n"
        "5. For bullet points and lists, place emojis at the start of each item\n"
        "6. Use emojis to emphasize important concepts, but place them before the text\n"
        "7. Return only the enhanced text with emojis, no additional commentary\n\n"
        f"Original text:\n{text}"
    )

    try:
        payload: dict = {
            "model": model,
            "messages": [{"role": "user", "content": enhancement_prompt}],
        }
        response: dict = api_request("/chat/completions", payload, timeout=30)
        if "choices" in response and len(response["choices"]) > 0:
            return response["choices"][0]["message"]["content"].strip()
        return text
    except Exception as e:
        print(f"Warning: Emoji enhancement failed ({e}), returning original text", file=sys.stderr)
        return text


def load_context_from_file(date_str: str, debug: bool = False) -> str | None:
    """Load chat history from a specific date's markdown file."""
    base_path: Path = Path("/var/home/zach/Documents/notes/03_resources/ai_chats/providers")
    file_path: Path = base_path / f"{date_str}.md"

    if not file_path.exists():
        if debug:
            print(f"Debug: No context file found at {file_path}", file=sys.stderr)
        return None

    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            content: str = f.read()
        if debug:
            print(f"Debug: Loaded {len(content)} characters of context from {date_str}.md", file=sys.stderr)
        return f"=== Previous Chat History from {date_str} ===\n\n{content}\n\n=== End of Previous Chat History ===\n\n"
    except Exception as e:
        print(f"Warning: Could not load context from {file_path}: {e}", file=sys.stderr)
        return None


def calculate_cost(model: str, input_tokens: int, output_tokens: int) -> dict:
    """Calculate cost based on Perplexity pricing (per 1M tokens)."""
    model_pricing: dict = PRICING.get(model, PRICING["sonar-pro"])
    input_cost: float = (input_tokens / 1_000_000) * model_pricing["input"]
    output_cost: float = (output_tokens / 1_000_000) * model_pricing["output"]
    return {
        "input_cost": input_cost,
        "output_cost": output_cost,
        "total_cost": input_cost + output_cost,
    }


def print_summary_table(
    model: str,
    input_tokens: int,
    output_tokens: int,
    total_time: float,
    first_token_time: float | None,
    cost_info: dict,
    is_estimated: bool = False,
    use_color: bool = True,
    citations: list | None = None,
):
    """Print a formatted summary table with usage stats."""
    if use_color:
        CYAN = '\033[96m'
        GREEN = '\033[92m'
        YELLOW = '\033[93m'
        BLUE = '\033[94m'
        MAGENTA = '\033[95m'
        BOLD = '\033[1m'
        END = '\033[0m'
    else:
        CYAN = GREEN = YELLOW = BLUE = MAGENTA = BOLD = END = ''

    total_tokens: int = input_tokens + output_tokens
    width: int = 50

    ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')

    def strip_ansi(text: str) -> str:
        return ansi_escape.sub('', text)

    def make_line(left: str, right: str, left_width: int = 22) -> str:
        left_plain: str = strip_ansi(left)
        right_plain: str = strip_ansi(right)
        left_part: str = left + ' ' * (left_width - len(left_plain))
        remaining_width: int = 48 - left_width - 1
        right_part: str = right + ' ' * (remaining_width - len(right_plain))
        content: str = f"{left_part} {right_part}"
        return f"{CYAN}║{END} {content} {CYAN}║{END}"

    print(f"\n{BOLD}{CYAN}╔{'═' * width}╗{END}", file=sys.stderr)

    title: str = "API Usage Summary"
    title_pad_left: int = (width - len(title)) // 2
    title_pad_right: int = width - len(title) - title_pad_left
    print(f"{BOLD}{CYAN}║{' ' * title_pad_left}{title}{' ' * title_pad_right}║{END}", file=sys.stderr)

    print(f"{BOLD}{CYAN}╠{'═' * width}╣{END}", file=sys.stderr)

    model_display: str = model if len(model) <= 30 else model[:27] + "..."
    print(make_line(f"{BOLD}Model:{END}", f"{GREEN}{model_display}{END}"), file=sys.stderr)
    print(f"{CYAN}╠{'─' * width}╣{END}", file=sys.stderr)

    print(make_line(f"{BOLD}Token Usage:{END}", ""), file=sys.stderr)
    est_marker: str = " (est)" if is_estimated else ""
    print(make_line("  Input:", f"{YELLOW}{input_tokens:,}{est_marker}{END} tokens"), file=sys.stderr)
    print(make_line("  Output:", f"{YELLOW}{output_tokens:,}{est_marker}{END} tokens"), file=sys.stderr)
    print(make_line("  Total:", f"{BOLD}{YELLOW}{total_tokens:,}{est_marker}{END} tokens"), file=sys.stderr)
    print(f"{CYAN}╠{'─' * width}╣{END}", file=sys.stderr)

    print(make_line(f"{BOLD}Performance:{END}", ""), file=sys.stderr)
    if first_token_time:
        print(make_line("  Time to first token:", f"{BLUE}{first_token_time:.2f}s{END}"), file=sys.stderr)
    print(make_line("  Total time:", f"{BLUE}{total_time:.2f}s{END}"), file=sys.stderr)
    if output_tokens > 0 and total_time > 0:
        tokens_per_sec: float = output_tokens / total_time
        print(make_line("  Tokens/second:", f"{BLUE}{tokens_per_sec:.1f}{END}"), file=sys.stderr)
    print(f"{CYAN}╠{'─' * width}╣{END}", file=sys.stderr)

    print(make_line(f"{BOLD}Cost Breakdown:{END}", ""), file=sys.stderr)
    print(make_line("  Input cost:", f"{MAGENTA}${cost_info['input_cost']:.6f}{END}"), file=sys.stderr)
    print(make_line("  Output cost:", f"{MAGENTA}${cost_info['output_cost']:.6f}{END}"), file=sys.stderr)
    print(make_line(f"  {BOLD}Total cost:{END}", f"{BOLD}{MAGENTA}${cost_info['total_cost']:.6f}{END}"), file=sys.stderr)

    if citations:
        print(f"{CYAN}╠{'─' * width}╣{END}", file=sys.stderr)
        print(make_line(f"{BOLD}Citations:{END}", f"{GREEN}{len(citations)}{END} sources"), file=sys.stderr)

    print(f"{BOLD}{CYAN}╚{'═' * width}╝{END}", file=sys.stderr)


def print_citations(citations: list, use_color: bool = True):
    """Print citation URLs after the response."""
    if not citations:
        return

    if use_color:
        CYAN = '\033[96m'
        BOLD = '\033[1m'
        END = '\033[0m'
    else:
        CYAN = BOLD = END = ''

    print(f"\n{BOLD}{CYAN}Citations:{END}", file=sys.stderr)
    for i, url in enumerate(citations, 1):
        print(f"  [{i}] {CYAN}{url}{END}", file=sys.stderr)


def print_related_questions(questions: list, use_color: bool = True):
    """Print related questions after the response."""
    if not questions:
        return

    if use_color:
        YELLOW = '\033[93m'
        BOLD = '\033[1m'
        END = '\033[0m'
    else:
        YELLOW = BOLD = END = ''

    print(f"\n{BOLD}{YELLOW}Related Questions:{END}", file=sys.stderr)
    for i, q in enumerate(questions, 1):
        print(f"  {YELLOW}{i}. {q}{END}", file=sys.stderr)


def print_search_results(results: list, use_color: bool = True):
    """Print formatted search results from the /search API."""
    if use_color:
        CYAN = '\033[96m'
        GREEN = '\033[92m'
        YELLOW = '\033[93m'
        BLUE = '\033[94m'
        BOLD = '\033[1m'
        DIM = '\033[2m'
        END = '\033[0m'
    else:
        CYAN = GREEN = YELLOW = BLUE = BOLD = DIM = END = ''

    if not results:
        print(f"{YELLOW}No results found.{END}")
        return

    for i, r in enumerate(results, 1):
        title: str = r.get("title", "Untitled")
        url: str = r.get("url", "")
        snippet: str = r.get("snippet", "")
        date: str | None = r.get("date")
        last_updated: str | None = r.get("last_updated")

        print(f"{BOLD}{GREEN}[{i}]{END} {BOLD}{title}{END}")
        print(f"    {CYAN}{url}{END}")
        if date:
            date_str: str = f"Published: {date}"
            if last_updated:
                date_str += f" | Updated: {last_updated}"
            print(f"    {DIM}{date_str}{END}")
        if snippet:
            # Wrap snippet lines with indentation
            wrapped: str = snippet.replace("\n", "\n    ")
            print(f"    {wrapped}")
        print()


def save_chat_transaction(
    provider: str,
    model: str,
    prompt: str,
    response: str,
    metadata: dict | None = None,
):
    """Save chat transaction to markdown file organized by date."""
    base_path: Path = Path("/var/home/zach/Documents/notes/03_resources/ai_chats/providers")
    base_path.mkdir(parents=True, exist_ok=True)

    today: datetime = datetime.now()
    file_path: Path = base_path / today.strftime("%Y-%m-%d.md")
    timestamp: str = today.strftime("%Y-%m-%d %H:%M:%S")

    content: str = f"\n# {timestamp}\n\n"
    content += f"## Prompt\n\n```\n{prompt}\n```\n\n"
    content += f"## Response\n\n{response}\n\n"

    if metadata:
        content += "## Metadata\n\n"
        content += f"- **Provider**: {provider}\n"
        content += f"- **Model**: {model}\n"
        if 'input_tokens' in metadata:
            content += f"- **Input Tokens**: {metadata['input_tokens']:,}\n"
        if 'output_tokens' in metadata:
            content += f"- **Output Tokens**: {metadata['output_tokens']:,}\n"
        if 'total_tokens' in metadata:
            content += f"- **Total Tokens**: {metadata['total_tokens']:,}\n"
        if 'cost_info' in metadata:
            ci: dict = metadata['cost_info']
            content += f"- **Input Cost**: ${ci['input_cost']:.6f}\n"
            content += f"- **Output Cost**: ${ci['output_cost']:.6f}\n"
            content += f"- **Total Cost**: ${ci['total_cost']:.6f}\n"
        if 'total_time' in metadata:
            content += f"- **Total Time**: {metadata['total_time']:.2f}s\n"
        if 'first_token_time' in metadata and metadata['first_token_time']:
            content += f"- **Time to First Token**: {metadata['first_token_time']:.2f}s\n"
        if 'stream_mode' in metadata:
            content += f"- **Streaming**: {metadata['stream_mode']}\n"
        if 'citations' in metadata and metadata['citations']:
            content += f"- **Citations**: {len(metadata['citations'])} sources\n"
            for i, url in enumerate(metadata['citations'], 1):
                content += f"  - [{i}] {url}\n"

    content += "\n---\n"

    try:
        with open(file_path, 'a', encoding='utf-8') as f:
            f.write(content)
    except Exception as e:
        print(f"Warning: Could not save chat transaction: {e}", file=sys.stderr)


def decode_embedding(b64_string: str) -> list[float]:
    """Decode a base64-encoded int8 embedding vector to a list of floats.

    The Perplexity embedding API returns base64-encoded signed int8 values.
    We decode and normalize to float range [-1.0, 1.0] for compatibility
    with cosine similarity and other distance metrics.
    """
    raw: bytes = base64.b64decode(b64_string)
    values: tuple = struct.unpack(f'{len(raw)}b', raw)
    return [v / 127.0 for v in values]


# === Argument parsing ===

model_choices: list[str] = list(MODELS.keys())
model_help: str = (
    "Model to use (default: sonar-pro). Available: "
    + ", ".join(model_choices)
    + ". Use -L/--list-models for details."
)

parser: argparse.ArgumentParser = argparse.ArgumentParser(
    description="Query the Perplexity API from the command line",
    formatter_class=argparse.RawDescriptionHelpFormatter,
    epilog="""examples:
  echo "What is Rust?" | perpy
  perpy --prompt "Explain quantum computing"
  perpy --model sonar-reasoning-pro --prompt "Solve: what is 127 * 343?"
  perpy --search-mode academic --prompt "latest research on mRNA vaccines"
  perpy -f code.py --prompt "Review this code"
  perpy --model sonar-deep-research --prompt "comprehensive analysis of EV market"
  perpy --embedding --prompt "hello world"
  perpy --disable-search --prompt "write a haiku about rain"
  perpy --search --prompt "linux kernel 6.x performance improvements"
  perpy --search --prompt "rust async" --search-domain-filter github.com --max-results 5
""",
)

# Core options
parser.add_argument("--prompt", help="Prompt to send (can also pipe via stdin)")
parser.add_argument("--model", default="sonar-pro", choices=model_choices, help=model_help)
parser.add_argument("--debug", action="store_true", help="Enable debug mode (shows request details)")

# Output format
parser.add_argument("--json", action="store_true", help="Return response without streaming")
parser.add_argument("-S", "--no-streaming", action="store_true", help="Disable streaming mode")
parser.add_argument("--no-color", action="store_true", help="Disable colored output")
parser.add_argument("--summary", action="store_true", help="Show usage summary with token counts, timing, and costs")
parser.add_argument("--citations", action="store_true", help="Display citation URLs after the response")

# File input
parser.add_argument("-f", "--file", action="append", dest="files",
                    help="Include file content in context (repeatable)")

# Model listing
parser.add_argument("-L", "--list-models", action="store_true", help="List available models")
parser.add_argument("--show-limits", action="store_true", help="Show token limits for models")

# Search options
parser.add_argument("--search-mode", choices=["web", "academic", "sec"],
                    help="Search source: web (default), academic (scholarly), sec (SEC filings)")
parser.add_argument("--search-domain-filter", action="append", dest="search_domains",
                    help="Limit search to specific domains (repeatable, e.g. --search-domain-filter github.com)")
parser.add_argument("--search-recency-filter", choices=["hour", "day", "week", "month", "year"],
                    help="Filter search results by recency")
parser.add_argument("--search-language-filter",
                    help="Filter search by language (ISO 639-1 code, e.g. en, fr, de)")
parser.add_argument("--search-after-date",
                    help="Only return results published after this date (MM/DD/YYYY)")
parser.add_argument("--search-before-date",
                    help="Only return results published before this date (MM/DD/YYYY)")
parser.add_argument("--search-context-size", choices=["low", "medium", "high"], default="low",
                    help="Amount of search context to include (default: low)")
parser.add_argument("--disable-search", action="store_true",
                    help="Disable web search; model responds from training data only")
parser.add_argument("--enable-search-classifier", action="store_true",
                    help="Let the model decide if web search is needed")

# Generation options
parser.add_argument("--temperature", type=float,
                    help="Sampling temperature (0.0-2.0). Higher = more random")
parser.add_argument("--top-p", type=float,
                    help="Nucleus sampling parameter (0.0-1.0)")
parser.add_argument("--max-tokens", type=int,
                    help="Maximum output tokens (overrides model default)")
parser.add_argument("--reasoning-effort", choices=["minimal", "low", "medium", "high"],
                    help="Control reasoning depth (for sonar-reasoning-pro)")
parser.add_argument("--language-preference",
                    help="Preferred response language (ISO 639-1 code, e.g. en, fr, de)")

# Response enrichment
parser.add_argument("--return-images", action="store_true",
                    help="Include image results in the response")
parser.add_argument("--return-related-questions", action="store_true",
                    help="Generate suggested follow-up questions")

# Search API (raw web search, no LLM)
parser.add_argument("--search", action="store_true",
                    help="Use the Search API for raw ranked results (no LLM). $5/1K requests flat rate.")
parser.add_argument("--max-results", type=int, default=10,
                    help="Max search results to return (1-20, default: 10). Only with --search.")
parser.add_argument("--country",
                    help="ISO 3166-1 alpha-2 country code for search localization (e.g. US, GB, DE). Only with --search.")
parser.add_argument("--links-only", action="store_true",
                    help="With --search, output only the URLs (one per line)")

# Embedding
parser.add_argument("--embedding", action="store_true",
                    help="Generate an embedding vector instead of a text response")
parser.add_argument("--embedding-model", default="pplx-embed-v1-0.6b",
                    choices=list(EMBEDDING_MODELS.keys()),
                    help="Embedding model to use (default: pplx-embed-v1-0.6b)")

# Personality and emoji
parser.add_argument("--personality",
                    help="Set a personality/role. Builtins: " + ", ".join(PERSONALITIES.keys()) + ". Or use a custom description.")
parser.add_argument("--emojis", nargs="?", const="light", choices=["light", "heavy"],
                    help="Encourage emoji usage ('light' default, or 'heavy')")
parser.add_argument("--enhance-emojis", action="store_true",
                    help="Post-process the response to add emojis via a secondary AI call")

# Workflow
parser.add_argument("--dry-run", action="store_true",
                    help="Show what would be sent without making the API call")
parser.add_argument("--no-preserve", action="store_true",
                    help="Don't save the chat transaction to the second-brain markdown file")
parser.add_argument("--use-context", action="store_true",
                    help="Include today's chat history as conversation context")
parser.add_argument("--use-context-from",
                    help="Include chat history from a specific date (YYYY-MM-DD)")

args: argparse.Namespace = parser.parse_args()


# === Handle info commands ===

def use_colors() -> bool:
    return not args.no_color and environ.get("NO_COLOR", "").lower() not in ("1", "true")


if args.list_models:
    colors: bool = use_colors()

    class C:
        HEADER = '\033[95m' if colors else ''
        BLUE = '\033[94m' if colors else ''
        CYAN = '\033[96m' if colors else ''
        GREEN = '\033[92m' if colors else ''
        YELLOW = '\033[93m' if colors else ''
        BOLD = '\033[1m' if colors else ''
        END = '\033[0m' if colors else ''

    print(f"\n{C.BOLD}{C.CYAN}Available Chat Models:{C.END}")

    max_id: int = max(len(m) for m in MODELS)
    max_name: int = max(len(v["name"]) for v in MODELS.values())
    max_desc: int = max(len(v["description"]) for v in MODELS.values())
    max_id = max(max_id, len("Model ID"))
    max_name = max(max_name, len("Name"))
    max_desc = max(max_desc, len("Description"))

    print(f"{C.BOLD}{'─' * (max_id + max_name + max_desc + 6)}{C.END}")
    print(f"{C.BOLD}{C.HEADER}{'Model ID':<{max_id}} {'Name':<{max_name}} {'Description':<{max_desc}}{C.END}")
    print(f"{C.BOLD}{'─' * max_id} {'─' * max_name} {'─' * max_desc}{C.END}")

    for i, (model_id, info) in enumerate(MODELS.items()):
        color = C.CYAN if i % 2 == 0 else C.BLUE
        print(f"{color}{model_id:<{max_id}}{C.END} "
              f"{C.GREEN}{info['name']:<{max_name}}{C.END} "
              f"{C.YELLOW}{info['description']:<{max_desc}}{C.END}")

    print(f"{C.BOLD}{'─' * (max_id + max_name + max_desc + 6)}{C.END}")
    print(f"{C.BOLD}Total: {C.GREEN}{len(MODELS)}{C.END}\n")

    print(f"{C.BOLD}{C.CYAN}Available Embedding Models:{C.END}")

    max_eid: int = max(len(m) for m in EMBEDDING_MODELS)
    max_ename: int = max(len(v["name"]) for v in EMBEDDING_MODELS.values())
    max_eid = max(max_eid, len("Model ID"))
    max_ename = max(max_ename, len("Name"))

    print(f"{C.BOLD}{'─' * (max_eid + max_ename + 20)}{C.END}")
    print(f"{C.BOLD}{C.HEADER}{'Model ID':<{max_eid}} {'Name':<{max_ename}} {'Dims':<6} {'$/1M':<8}{C.END}")
    print(f"{C.BOLD}{'─' * max_eid} {'─' * max_ename} {'─' * 6} {'─' * 8}{C.END}")

    for i, (model_id, info) in enumerate(EMBEDDING_MODELS.items()):
        color = C.CYAN if i % 2 == 0 else C.BLUE
        ctx_marker: str = " (ctx)" if info.get("contextual") else ""
        print(f"{color}{model_id:<{max_eid}}{C.END} "
              f"{C.GREEN}{info['name'] + ctx_marker:<{max_ename + 6}}{C.END} "
              f"{C.YELLOW}{info['dimensions']:<6}{C.END} "
              f"{C.YELLOW}${info['price_per_m']:<7.3f}{C.END}")

    print(f"{C.BOLD}{'─' * (max_eid + max_ename + 20)}{C.END}")
    print(f"{C.BOLD}Total: {C.GREEN}{len(EMBEDDING_MODELS)}{C.END}\n")
    sys.exit(0)

if args.show_limits:
    colors = use_colors()

    class C:
        HEADER = '\033[95m' if colors else ''
        BLUE = '\033[94m' if colors else ''
        CYAN = '\033[96m' if colors else ''
        GREEN = '\033[92m' if colors else ''
        YELLOW = '\033[93m' if colors else ''
        BOLD = '\033[1m' if colors else ''
        END = '\033[0m' if colors else ''

    print(f"\n{C.BOLD}{C.CYAN}Perplexity Model Token Limits:{C.END}")
    print(f"{C.BOLD}{'─' * 70}{C.END}")

    print(f"{C.BOLD}{C.HEADER}{'Model':<25} {'Context Window':<18} {'Max Output':<15} {'Input $/1M':<12} {'Output $/1M':<12}{C.END}")
    print(f"{C.BOLD}{'─' * 25} {'─' * 18} {'─' * 15} {'─' * 12} {'─' * 12}{C.END}")

    for i, (model_id, info) in enumerate(MODELS.items()):
        color = C.CYAN if i % 2 == 0 else C.BLUE
        pricing: dict = PRICING.get(model_id, {})
        ctx: str = f"{info['context']:,} tokens"
        out: str = f"{info['max_output']:,} tokens"
        inp_price: str = f"${pricing.get('input', 0):.2f}"
        out_price: str = f"${pricing.get('output', 0):.2f}"

        print(f"{color}{model_id:<25}{C.END} "
              f"{C.GREEN}{ctx:<18}{C.END} "
              f"{C.YELLOW}{out:<15}{C.END} "
              f"{C.BLUE}{inp_price:<12}{C.END} "
              f"{C.BLUE}{out_price:<12}{C.END}")

    print(f"{C.BOLD}{'─' * 70}{C.END}")

    if args.model:
        limits: dict = get_model_limits(args.model)
        print(f"\n{C.BOLD}Current model ({args.model}) limits:{C.END}")
        print(f"  Context: {C.GREEN}{limits['input']:,}{C.END} tokens")
        print(f"  Max output: {C.YELLOW}{limits['output']:,}{C.END} tokens")

    print()
    sys.exit(0)


# === Debug info ===

if args.debug:
    print(f"Debug: Using Perplexity API (direct, no perplexipy)", file=sys.stderr)
    print(f"Debug: API key (partially hidden): {api_key[:5]}...{api_key[-4:]}", file=sys.stderr)
