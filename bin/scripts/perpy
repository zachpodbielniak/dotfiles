# === Read input ===

file_contents: list[str] = []
if args.files:
    for file_path in args.files:
        try:
            with open(file_path, 'r') as f:
                file_contents.append(f"=== File: {file_path} ===\n{f.read()}\n")
        except IOError as e:
            print(f"Warning: Could not read file {file_path}: {e}", file=sys.stderr)

query: str = ""
if not sys.stdin.isatty() or sys.stdin in select.select([sys.stdin], [], [], 0)[0]:
    query = sys.stdin.read()
elif not args.prompt and not args.files and not args.embedding:
    print("Error: No input provided. Use --prompt, -f/--file, or pipe input via stdin", file=sys.stderr)
    sys.exit(1)

# Combine inputs
combined_parts: list[str] = []
if file_contents:
    combined_parts.extend(file_contents)
if args.prompt:
    combined_parts.append(args.prompt)
if query:
    combined_parts.append(query)

query = "\n".join(combined_parts) if combined_parts else ""

# Warn if input might exceed context window
if query and not args.embedding:
    estimated_input_tokens: int = len(query) // 4
    limits = get_model_limits(args.model)
    if estimated_input_tokens > limits["input"]:
        print(f"Warning: Input text (~{estimated_input_tokens:,} tokens) may exceed model context ({limits['input']:,} tokens).", file=sys.stderr)
        print(f"Consider using a model with larger context or reducing input size.", file=sys.stderr)

# Load conversation context
context_parts: list[str] = []

if args.use_context:
    today_str: str = datetime.now().strftime("%Y-%m-%d")
    context: str | None = load_context_from_file(today_str, debug=args.debug)
    if context:
        context_parts.append(context)

if args.use_context_from:
    try:
        datetime.strptime(args.use_context_from, "%Y-%m-%d")
        context = load_context_from_file(args.use_context_from, debug=args.debug)
        if context:
            context_parts.append(context)
    except ValueError:
        print(f"Error: Invalid date format '{args.use_context_from}'. Use YYYY-MM-DD.", file=sys.stderr)
        sys.exit(1)

if context_parts:
    context_str: str = "\n".join(context_parts)
    query = context_str + "\nCurrent Query:\n" + query if query else context_str

# Prepend personality and emoji prompts
prompt_parts: list[str] = []
if args.personality:
    p: str = get_personality_prompt(args.personality)
    if p:
        prompt_parts.append(p)
if args.emojis:
    e: str = get_emoji_prompt(args.emojis)
    if e:
        prompt_parts.append(e)
if prompt_parts:
    combined_prompt: str = "".join(prompt_parts)
    query = combined_prompt + query if query else combined_prompt.rstrip()

if args.debug:
    print(f"Debug: Query: {query[:100]}{'...' if len(query) > 100 else ''}", file=sys.stderr)


# === Dry-run mode ===

if args.dry_run:
    print("=== DRY-RUN MODE ===", file=sys.stderr)
    print("API provider: Perplexity (direct HTTP)", file=sys.stderr)
    print(f"API key (partially hidden): {api_key[:5]}...{api_key[-4:]}", file=sys.stderr)

    if args.embedding:
        print(f"\nMode: Embedding generation", file=sys.stderr)
        print(f"Endpoint: POST {API_BASE}/v1/embeddings", file=sys.stderr)
        print(f"Embedding model: {args.embedding_model}", file=sys.stderr)
        em_info: dict = EMBEDDING_MODELS.get(args.embedding_model, {})
        print(f"Dimensions: {em_info.get('dimensions', 'unknown')}", file=sys.stderr)
    elif args.search:
        print(f"\nMode: Web Search (raw results, no LLM)", file=sys.stderr)
        print(f"Endpoint: POST {API_BASE}/search", file=sys.stderr)
        print(f"Max results: {args.max_results}", file=sys.stderr)
        print(f"Cost: ~$0.005 per request (flat rate)", file=sys.stderr)
        if args.country:
            print(f"Country: {args.country}", file=sys.stderr)
        if args.search_domains:
            print(f"Domain filter: {', '.join(args.search_domains)}", file=sys.stderr)
        if args.search_recency_filter:
            print(f"Recency filter: {args.search_recency_filter}", file=sys.stderr)
        if args.search_language_filter:
            print(f"Language filter: {args.search_language_filter}", file=sys.stderr)
    else:
        print(f"\nMode: Chat completion", file=sys.stderr)
        print(f"Endpoint: POST {API_BASE}/chat/completions", file=sys.stderr)
        print(f"Model: {args.model}", file=sys.stderr)
        print(f"Streaming: {not (args.json or args.no_streaming)}", file=sys.stderr)
        if args.search_mode:
            print(f"Search mode: {args.search_mode}", file=sys.stderr)
        if args.search_domains:
            print(f"Domain filter: {', '.join(args.search_domains)}", file=sys.stderr)
        if args.search_recency_filter:
            print(f"Recency filter: {args.search_recency_filter}", file=sys.stderr)
        if args.disable_search:
            print(f"Search: DISABLED", file=sys.stderr)
        if args.reasoning_effort:
            print(f"Reasoning effort: {args.reasoning_effort}", file=sys.stderr)
        if args.temperature is not None:
            print(f"Temperature: {args.temperature}", file=sys.stderr)
        if args.top_p is not None:
            print(f"Top-p: {args.top_p}", file=sys.stderr)
        if args.max_tokens is not None:
            print(f"Max tokens: {args.max_tokens}", file=sys.stderr)

    if query and len(query) <= 1000:
        print(f"\nFull prompt:\n{query}", file=sys.stderr)
    elif query:
        print(f"\nFull prompt (truncated):\n{query[:1000]}... [truncated]", file=sys.stderr)

    print("=== END DRY-RUN ===", file=sys.stderr)
    sys.exit(0)


# === Embedding mode ===

if args.embedding:
    if args.debug:
        print(f"Debug: Generating embedding with model {args.embedding_model}", file=sys.stderr)

    start_time: float = time.time() if args.summary else 0.0

    try:
        payload: dict = {
            "model": args.embedding_model,
            "input": query if query else "",
        }

        em_info = EMBEDDING_MODELS.get(args.embedding_model, {})
        if em_info.get("dimensions"):
            payload["dimensions"] = em_info["dimensions"]

        response: dict = api_request("/v1/embeddings", payload, timeout=60)

        embedding: list[float] = []
        if "data" in response and len(response["data"]) > 0:
            b64_embedding: str = response["data"][0].get("embedding", "")
            if b64_embedding:
                embedding = decode_embedding(b64_embedding)

        print(json.dumps({"embedding": embedding}))

        if args.summary:
            end_time: float = time.time()
            total_time: float = end_time - start_time
            usage: dict = response.get("usage", {})
            input_tokens: int = usage.get("prompt_tokens", len(query) // 4)
            price: float = em_info.get("price_per_m", 0.004)
            cost_info: dict = {
                "input_cost": (input_tokens / 1_000_000) * price,
                "output_cost": 0.0,
                "total_cost": (input_tokens / 1_000_000) * price,
            }
            print_summary_table(
                model=args.embedding_model,
                input_tokens=input_tokens,
                output_tokens=0,
                total_time=total_time,
                first_token_time=None,
                cost_info=cost_info,
                is_estimated=False,
                use_color=use_colors(),
            )

    except urllib.error.HTTPError as e:
        error_body: str = e.read().decode("utf-8", errors="replace")
        print(f"Error: API returned {e.code}: {error_body}", file=sys.stderr)
        print(json.dumps({"embedding": []}))
    except Exception as e:
        if args.debug:
            print(f"Debug: Error generating embedding: {e}", file=sys.stderr)
        print(json.dumps({"embedding": []}))

    sys.exit(0)


# === Search API mode ===

if args.search:
    if args.debug:
        print("Debug: Using Search API (/search endpoint)", file=sys.stderr)

    search_payload: dict = {
        "query": query,
        "max_results": max(1, min(20, args.max_results)),
    }

    if args.country:
        search_payload["country"] = args.country
    if args.search_domains:
        search_payload["search_domain_filter"] = args.search_domains
    if args.search_recency_filter:
        search_payload["search_recency_filter"] = args.search_recency_filter
    if args.search_language_filter:
        search_payload["search_language_filter"] = [args.search_language_filter]
    if args.search_after_date:
        search_payload["search_after_date_filter"] = args.search_after_date
    if args.search_before_date:
        search_payload["search_before_date_filter"] = args.search_before_date

    if args.debug:
        print(f"Debug: Payload: {json.dumps(search_payload, indent=2)}", file=sys.stderr)

    if args.dry_run:
        print("=== DRY-RUN MODE ===", file=sys.stderr)
        print(f"Endpoint: POST {API_BASE}/search", file=sys.stderr)
        print(f"Payload: {json.dumps(search_payload, indent=2)}", file=sys.stderr)
        print("=== END DRY-RUN ===", file=sys.stderr)
        sys.exit(0)

    start_time = time.time() if args.summary else 0.0

    try:
        response = api_request("/search", search_payload, timeout=30)
        results: list = response.get("results", [])

        if args.links_only:
            for r in results:
                print(r.get("url", ""))
        elif args.json or args.no_streaming:
            print(json.dumps(response, indent=2))
        else:
            print_search_results(results, use_color=use_colors())

        if args.summary:
            end_time = time.time()
            total_time = end_time - start_time
            print(f"\nSearch completed in {total_time:.2f}s | {len(results)} results | Cost: ~$0.005", file=sys.stderr)

    except urllib.error.HTTPError as e:
        error_body = e.read().decode("utf-8", errors="replace")
        print(f"Error: API returned {e.code}: {error_body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: Could not connect to API: {e.reason}", file=sys.stderr)
        sys.exit(1)

    sys.exit(0)


# === Build chat completion request ===

def build_payload(query_text: str, stream: bool = False) -> dict:
    """Build the chat/completions request payload from args and query text."""
    messages: list[dict] = []

    # Add system message if personality is set
    if args.personality:
        system_content: str = get_personality_prompt(args.personality).strip()
        if system_content:
            messages.append({"role": "system", "content": system_content})
            # Remove personality from user query since it's now in system message
            personality_prompt: str = get_personality_prompt(args.personality)
            if query_text.startswith(personality_prompt):
                query_text = query_text[len(personality_prompt):]

    messages.append({"role": "user", "content": query_text})

    payload: dict = {
        "model": args.model,
        "messages": messages,
        "stream": stream,
    }

    # Generation parameters
    if args.max_tokens is not None:
        payload["max_tokens"] = args.max_tokens
    if args.temperature is not None:
        payload["temperature"] = args.temperature
    if args.top_p is not None:
        payload["top_p"] = args.top_p

    # Search options
    if args.disable_search:
        payload["disable_search"] = True
    if args.enable_search_classifier:
        payload["enable_search_classifier"] = True
    if args.search_mode:
        payload["search_mode"] = args.search_mode
    if args.search_domains:
        payload["search_domain_filter"] = args.search_domains
    if args.search_recency_filter:
        payload["search_recency_filter"] = args.search_recency_filter
    if args.search_language_filter:
        payload["search_language_filter"] = args.search_language_filter
    if args.search_after_date:
        payload["search_after_date_filter"] = args.search_after_date
    if args.search_before_date:
        payload["search_before_date_filter"] = args.search_before_date

    # Web search options
    web_search_opts: dict = {}
    if args.search_context_size and args.search_context_size != "low":
        web_search_opts["search_context_size"] = args.search_context_size
    if web_search_opts:
        payload["web_search_options"] = web_search_opts

    # Response enrichment
    if args.return_images:
        payload["return_images"] = True
    if args.return_related_questions:
        payload["return_related_questions"] = True

    # Reasoning
    if args.reasoning_effort:
        payload["reasoning_effort"] = args.reasoning_effort

    # Language preference
    if args.language_preference:
        payload["language_preference"] = args.language_preference

    return payload


# === Execute chat completion ===

# Use longer timeout for deep research
timeout: int = 600 if args.model == "sonar-deep-research" else 120

if args.json or args.no_streaming:
    # Non-streaming mode
    if args.debug:
        print("Debug: Executing non-streaming query", file=sys.stderr)

    start_time = time.time() if args.summary else 0.0

    try:
        payload = build_payload(query, stream=False)

        if args.debug:
            print(f"Debug: Payload: {json.dumps(payload, indent=2)[:500]}", file=sys.stderr)

        response = api_request("/chat/completions", payload, timeout=timeout)

        result: str = ""
        if "choices" in response and len(response["choices"]) > 0:
            result = response["choices"][0]["message"]["content"]

        citations_list: list = response.get("citations", [])
        related_questions: list = response.get("related_questions", [])

        # Enhance with emojis if requested
        if args.enhance_emojis and result:
            print("Enhancing response with emojis...", file=sys.stderr)
            result = enhance_with_emojis(result)

        print(result)

        # Show citations if requested
        if args.citations:
            print_citations(citations_list, use_color=use_colors())
        if args.return_related_questions and related_questions:
            print_related_questions(related_questions, use_color=use_colors())

        # Usage stats from API response
        usage = response.get("usage", {})
        input_tokens = usage.get("prompt_tokens", len(query) // 4)
        output_tokens: int = usage.get("completion_tokens", len(result) // 4)
        is_estimated: bool = "prompt_tokens" not in usage

        cost_info = calculate_cost(args.model, input_tokens, output_tokens)

        if args.summary:
            end_time = time.time()
            total_time = end_time - start_time
            print_summary_table(
                model=args.model,
                input_tokens=input_tokens,
                output_tokens=output_tokens,
                total_time=total_time,
                first_token_time=None,
                cost_info=cost_info,
                is_estimated=is_estimated,
                use_color=use_colors(),
                citations=citations_list,
            )

        # Save chat transaction
        if not args.no_preserve:
            total_time_val: float = time.time() - start_time if start_time else 0.0
            metadata: dict = {
                'stream_mode': False,
                'input_tokens': input_tokens,
                'output_tokens': output_tokens,
                'total_tokens': input_tokens + output_tokens,
                'cost_info': cost_info,
                'total_time': total_time_val,
                'citations': citations_list,
            }
            save_chat_transaction("Perplexity", args.model, query, result, metadata)

    except urllib.error.HTTPError as e:
        error_body = e.read().decode("utf-8", errors="replace")
        print(f"Error: API returned {e.code}: {error_body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: Could not connect to API: {e.reason}", file=sys.stderr)
        sys.exit(1)

else:
    # Streaming mode
    if args.debug:
        print("Debug: Executing streaming query", file=sys.stderr)

    start_time = time.time() if args.summary else 0.0
    first_token_time: float | None = None
    accumulated_content: str = ""
    citations_list = []
    related_questions = []
    usage = {}

    try:
        payload = build_payload(query, stream=True)

        if args.debug:
            print(f"Debug: Payload: {json.dumps(payload, indent=2)[:500]}", file=sys.stderr)

        resp = api_request("/chat/completions", payload, stream=True, timeout=timeout)

        for raw_line in resp:
            line: str = raw_line.decode("utf-8").rstrip("\n\r")

            if not line or not line.startswith("data: "):
                continue

            data: str = line[6:]
            if data.strip() == "[DONE]":
                break

            try:
                chunk: dict = json.loads(data)
            except json.JSONDecodeError:
                if args.debug:
                    print(f"Debug: Could not parse SSE chunk: {data[:100]}", file=sys.stderr)
                continue

            # Extract content delta
            if "choices" in chunk and len(chunk["choices"]) > 0:
                delta: dict = chunk["choices"][0].get("delta", {})
                content: str = delta.get("content", "")

                if content:
                    if args.summary and first_token_time is None:
                        first_token_time = time.time()

                    if not args.enhance_emojis:
                        print(content, end="", flush=True)
                    accumulated_content += content

            # Capture usage from final chunk
            if "usage" in chunk:
                usage = chunk["usage"]
            if "citations" in chunk:
                citations_list = chunk["citations"]
            if "related_questions" in chunk:
                related_questions = chunk["related_questions"]

        resp.close()

        # Enhance with emojis if requested (after streaming completes)
        if args.enhance_emojis and accumulated_content:
            print("Enhancing response with emojis...", file=sys.stderr)
            enhanced: str = enhance_with_emojis(accumulated_content)
            print(enhanced)
        elif not args.enhance_emojis:
            print()

        # Show citations if requested
        if args.citations:
            print_citations(citations_list, use_color=use_colors())
        if args.return_related_questions and related_questions:
            print_related_questions(related_questions, use_color=use_colors())

        # Usage stats
        input_tokens = usage.get("prompt_tokens", len(query) // 4)
        output_tokens = usage.get("completion_tokens", len(accumulated_content) // 4)
        is_estimated = "prompt_tokens" not in usage

        cost_info = calculate_cost(args.model, input_tokens, output_tokens)

        if args.summary:
            end_time = time.time()
            total_time = end_time - start_time
            ttft: float | None = (first_token_time - start_time) if first_token_time else None

            print_summary_table(
                model=args.model,
                input_tokens=input_tokens,
                output_tokens=output_tokens,
                total_time=total_time,
                first_token_time=ttft,
                cost_info=cost_info,
                is_estimated=is_estimated,
                use_color=use_colors(),
                citations=citations_list,
            )

        # Save chat transaction
        if not args.no_preserve and accumulated_content:
            total_time_val = time.time() - start_time if start_time else 0.0
            ttft_val: float | None = (first_token_time - start_time) if first_token_time else None
            metadata = {
                'stream_mode': True,
                'input_tokens': input_tokens,
                'output_tokens': output_tokens,
                'total_tokens': input_tokens + output_tokens,
                'cost_info': cost_info,
                'total_time': total_time_val,
                'first_token_time': ttft_val,
                'citations': citations_list,
            }
            save_chat_transaction("Perplexity", args.model, query, accumulated_content, metadata)

    except urllib.error.HTTPError as e:
        error_body = e.read().decode("utf-8", errors="replace")
        print(f"Error: API returned {e.code}: {error_body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: Could not connect to API: {e.reason}", file=sys.stderr)
        sys.exit(1)
