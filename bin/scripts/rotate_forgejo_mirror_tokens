See <https://www.gnu.org/licenses/> for details."""


def csv_list(value):
    return [item.strip() for item in value.split(",") if item.strip()]


def build_parser():
    parser = argparse.ArgumentParser(
        prog=SCRIPT_NAME,
        description="Rotate the GitHub/GitLab tokens stored in Forgejo pull/push mirrors "
                    "by reading each mirror's config and recreating it with the new token.",
        epilog=(
            "Modes:\n"
            "  pull  git-mirror.podbielniak.com (pull mirrors)  auth: $FORGEJO_MIRROR_TOKEN\n"
            "  push  git.podbielniak.com        (push mirrors)  auth: $FORGEJO_TOKEN\n"
            "  all   run pull then push\n\n"
            "New upstream tokens are read from $GITHUB_TOKEN / $GITLAB_TOKEN.\n\n"
            "Examples:\n"
            f"  {SCRIPT_NAME} pull --dry-run\n"
            f"  {SCRIPT_NAME} push --repo zachpodbielniak/foo,myorg/bar --no-confirm\n"
            f"  {SCRIPT_NAME} all --org zachpodbielniak --dry-run\n"
            f"  {SCRIPT_NAME} push --service gitlab --no-confirm   # only gitlab mirrors\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("mode", choices=["pull", "push", "all"],
                        help="which instance/mirror direction to rotate")
    parser.add_argument("--dry-run", action="store_true",
                        help="show planned delete/recreate for every mirror; change nothing")
    parser.add_argument("--org", type=csv_list, default=[], metavar="NAME[,NAME...]",
                        help="limit to these orgs/users (comma-separated)")
    parser.add_argument("--repo", type=csv_list, default=[], metavar="OWNER/REPO[,...]",
                        help="limit to these owner-qualified repos (comma-separated)")
    parser.add_argument("--service", type=csv_list, default=[], metavar="NAME[,NAME...]",
                        help="only rotate mirrors of these services, e.g. 'github' or 'gitlab' "
                             "(comma-separated); mirrors of other services are skipped")
    parser.add_argument("--no-confirm", action="store_true",
                        help="do not prompt before deleting/recreating mirrors")
    parser.add_argument("--parallel", type=int, default=1, metavar="N",
                        help="rotate up to N mirrors concurrently (default 1)")
    parser.add_argument("--delay", type=float, default=0, metavar="SECONDS",
                        help="sleep SECONDS after each successful rotation")
    parser.add_argument("--sync-on-commit", action="store_true",
                        help="force recreated PUSH mirrors to have sync-on-commit ENABLED, "
                             "overriding each mirror's current setting (push mode only)")
    parser.add_argument("--github-username", default="zachpodbielniak", metavar="USER",
                        help="username paired with $GITHUB_TOKEN for recreated push mirrors")
    parser.add_argument("--gitlab-username", default="oauth2", metavar="USER",
                        help="username paired with $GITLAB_TOKEN for recreated push mirrors")
    parser.add_argument("--forgejo-token-env", metavar="VAR",
                        help="override the env var holding the Forgejo API token for this run")
    parser.add_argument("--debug", action="store_true", help="verbose debugging (tokens masked)")
    parser.add_argument("--license", action="store_true", help="show license summary and exit")
    return parser


def validate_repo_specs(repo_specs):
    bad = [spec for spec in repo_specs if "/" not in spec]
    if bad:
        log_error(f"--repo values must be OWNER/REPO; invalid: {', '.join(bad)}")
        return False
    return True


def main(argv):
    global _DEBUG
    parser = build_parser()

    if "--license" in argv:
        print(LICENSE_BLURB)
        return 0

    args = parser.parse_args(argv)
    _DEBUG = args.debug

    args.service = [s.lower() for s in args.service]
    bad_services = [s for s in args.service if s not in KNOWN_SERVICES]
    if bad_services:
        log_error(f"--service values must be one of {sorted(KNOWN_SERVICES)}; invalid: {', '.join(bad_services)}")
        return 2

    if args.repo and not validate_repo_specs(args.repo):
        return 2
    if args.parallel < 1:
        log_error("--parallel must be >= 1")
        return 2

    modes = ["pull", "push"] if args.mode == "all" else [args.mode]
    total_errors = 0
    for mode in modes:
        counters = run_mode(mode, args)
        total_errors += counters["errors"]

    return 1 if total_errors else 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        log_warn("interrupted")
        sys.exit(130)
