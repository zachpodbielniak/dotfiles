set -euo pipefail

usage() {
    echo "Usage: emacsremote <tailscale-hostname>"
    echo ""
    echo "Connect emacsclient to a remote Emacs daemon over Tailscale."
    echo "Fetches the server file (contains auth key) from the remote host,"
    echo "then opens a terminal emacsclient session against it."
}

if [[ "$#" -ne 1 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage
    exit 1
fi

host="$1"
tmpfile="$(mktemp)"
trap 'rm -f "${tmpfile}"' EXIT

if ! scp "${host}:~/.config/emacs/server/server" "${tmpfile}" 2>/dev/null; then
    echo "Error: could not fetch server file from ${host}" >&2
    echo "Is the Emacs daemon running with server-use-tcp enabled?" >&2
    exit 1
fi

emacsclient -f "${tmpfile}" -nw
