set -euo pipefail

usage() {
    echo "Usage: emacsremote [-c|-nw] <hostname> [emacsclient args...]"
    echo ""
    echo "Connect to a remote Emacs daemon via SSH."
    echo ""
    echo "Modes:"
    echo "  -nw        terminal frame (default)"
    echo "  -c         GUI frame (auto-detects waypipe or X11 forwarding)"
    echo ""
    echo "Examples:"
    echo "  emacsremote srv-zach                # terminal frame"
    echo "  emacsremote -c srv-zach             # GUI frame"
    echo "  emacsremote srv-zach ~/file.txt     # open a file in terminal"
    echo "  emacsremote -c srv-zach ~/file.txt  # open a file in GUI"
}

if [[ "$#" -lt 1 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage
    exit 1
fi

# Parse mode flag if present
mode="-nw"
if [[ "$1" == "-c" ]] || [[ "$1" == "-nw" ]]; then
    mode="$1"
    shift
fi

if [[ "$#" -lt 1 ]]; then
    echo "Error: missing hostname" >&2
    usage
    exit 1
fi

host="$1"
shift

# Also check remaining args for mode flags
for arg in "$@"; do
    [[ "${arg}" == "-c" ]] && mode="-c" && break
done

if [[ "${mode}" == "-c" ]]; then
    # Detect display forwarding method for GUI frames
    if command -v waypipe &>/dev/null && ssh "${host}" "command -v waypipe" &>/dev/null; then
        waypipe ssh -t "${host}" emacsclient "$@" "${mode}"
    elif ssh "${host}" "command -v xdpyinfo" &>/dev/null; then
        ssh -X -t "${host}" emacsclient "$@" "${mode}"
    else
        echo "Error: GUI frame requires waypipe (Wayland) or X11 on both hosts" >&2
        echo "Install waypipe or use -nw for terminal mode" >&2
        exit 1
    fi
else
    ssh -t "${host}" emacsclient -nw "$@"
fi
