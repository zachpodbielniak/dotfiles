set -euo pipefail

usage() {
    echo "Usage: emacsremote <hostname> [emacsclient args...]"
    echo ""
    echo "Connect to a remote Emacs daemon via SSH."
    echo ""
    echo "Modes:"
    echo "  (default)  terminal frame (-nw over ssh)"
    echo "  -c         GUI frame (auto-detects waypipe or X11 forwarding)"
    echo ""
    echo "Examples:"
    echo "  emacsremote srv-zach                # terminal frame"
    echo "  emacsremote srv-zach -c             # GUI frame"
    echo "  emacsremote srv-zach -nw ~/file.txt # open a file in terminal"
}

if [[ "$#" -lt 1 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage
    exit 1
fi

host="$1"
shift

# Check if -c (GUI frame) was requested
gui=0
for arg in "$@"; do
    [[ "${arg}" == "-c" ]] && gui=1 && break
done

if [[ "${gui}" -eq 1 ]]; then
    # Detect display forwarding method for GUI frames
    if command -v waypipe &>/dev/null && ssh "${host}" "command -v waypipe" &>/dev/null; then
        waypipe ssh -t "${host}" emacsclient "$@"
    elif ssh "${host}" "command -v xdpyinfo" &>/dev/null; then
        ssh -X -t "${host}" emacsclient "$@"
    else
        echo "Error: GUI frame requires waypipe (Wayland) or X11 on both hosts" >&2
        echo "Install waypipe or use -nw for terminal mode" >&2
        exit 1
    fi
elif [[ "$#" -eq 0 ]]; then
    ssh -t "${host}" emacsclient -nw
else
    ssh -t "${host}" emacsclient "$@"
fi
