usage() {
    echo "Usage: rdp [options] <host>"
    echo "Connects to a remote host via xfreerdp"
    echo ""
    echo "Options:"
    echo "  -r, --resolution RES    Set RDP resolution (default: 1920x1080)"
    echo "  -d, --dynamic           Enable dynamic resolution (+dynamic-resolution)"
    echo "  -s, --smart-sizing      Enable smart sizing (/smart-sizing)"
    echo "  -f, --fullscreen        Enable fullscreen mode (+f)"
    echo "  -D, --drive NAME:PATH   Redirect a local directory as a drive share"
    echo "  -n, --network PROFILE    Set network profile (lan, broadband, modem, auto)"
    echo "  --verify                Enable certificate verification (disables /cert:ignore)"
    echo "  -h, --help               Display this help message"
    echo ""
    echo "Arguments:"
    echo "  host                    The RDP host to connect to"
    exit 0
}

RDP_USER="zach"
RDP_SIZE="1920x1080"
HOST=""
CERT_IGNORE=true
NETWORK_PROFILE="auto"
RDP_OPTS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--resolution)
            RDP_SIZE="$2"
            shift 2
            ;;
        -d|--dynamic)
            RDP_OPTS+=("+dynamic-resolution")
            shift
            ;;
        -s|--smart-sizing)
            RDP_OPTS+=("/smart-sizing")
            shift
            ;;
        -f|--fullscreen)
            RDP_OPTS+=("+f")
            shift
            ;;
        -D|--drive)
            RDP_OPTS+=("/drive:$2")
            shift 2
            ;;
        -n|--network)
            NETWORK_PROFILE="$2"
            shift 2
            ;;
        --verify)
            CERT_IGNORE=false
            shift
            ;;
        -h|--help)
            usage
            ;;
        -*)
            echo "Error: Unknown option $1" >&2
            usage
            ;;
        *)
            HOST="$1"
            shift
            ;;
    esac
done

if [[ -z "${HOST}" ]]; then
    echo "Error: No host specified." >&2
    usage
fi

if [[ "${HOST}" == "dt-zach" ]]; then
    RDP_USER="zachpodbielniak"
fi

# Base arguments
BASE_ARGS=(
    "/u:${RDP_USER}"
    "/v:${HOST}"
    "/sound"
    "/fonts"
    "/size:${RDP_SIZE}"
    "/timeout:20000"
    "/network:${NETWORK_PROFILE}"
    "+clipboard"
)

if [[ "${CERT_IGNORE}" == true ]]; then
    BASE_ARGS+=("/cert:ignore")
fi

# Combine base args with dynamic flags
FINAL_ARGS=("${BASE_ARGS[@]}" "${RDP_OPTS[@]}")

if [[ "$(uname -s)" == "Darwin" ]]; then
    xfreerdp "${FINAL_ARGS[@]}"
else
    if command -v distrobox &>/dev/null; then
        distrobox-enter util -- /usr/bin/xfreerdp "${FINAL_ARGS[@]}"
    else
        xfreerdp "${FINAL_ARGS[@]}"
    fi
fi
