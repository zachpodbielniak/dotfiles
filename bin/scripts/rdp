#xfreerdp /u:zach /v:$1 /sound /fonts /size:1920x968 /timeout:20000 +clipboard
#xfreerdp /u:zach /v:$1 /sound /fonts /size:1920x1020 /timeout:20000 +clipboard

RDP_USER="zach"

if [[ "${1}" == "dt-zach" ]]
then
    RDP_USER="zachpodbielniak"
fi

if [[ "$(uname -s)" == "Darwin" ]]
then
	xfreerdp /u:${RDP_USER} /v:${1} /sound /fonts /size:1920x1200 /timeout:20000 /cert:ignore +clipboard
else
	command -v distrobox &>/dev/null
	if [[ $? -eq 0 ]]
	then
		distrobox-enter util -- /usr/bin/xfreerdp /u:${RDP_USER} /v:${1} /sound /fonts /size:1920x1200 /timeout:20000 /cert:ignore +clipboard
		# distrobox-enter util -- /usr/bin/xfreerdp /u:zach /v:$1 /sound /fonts /timeout:20000 +clipboard /d: /dynamic-resolution #/p:$float
	else
		xfreerdp /u:${RDP_USER} /v:${1} /sound /fonts /size:1920x1200 /timeout:20000 /cert:ignore +clipboard
	fi
fi
