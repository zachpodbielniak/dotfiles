# convert markdown to org-mode via pandoc
set -euo pipefail

input=""
output=""

usage() {
    cat <<EOF
Convert Markdown to Org-mode using pandoc.

Usage:
    ${0##*/} [-i INPUT] [-o OUTPUT]
    cat file.md | ${0##*/} > file.org

Options:
    -i, --input FILE    Input markdown file (default: stdin)
    -o, --output FILE   Output org file (default: stdout)
    -h, --help          Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
    case "${1}" in
        -i|--input)
            input="${2:-}"
            shift 2
            ;;
        -o|--output)
            output="${2:-}"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            printf "unknown argument: %s\n" "${1}" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if ! command -v pandoc >/dev/null 2>&1; then
    printf "error: pandoc is not installed or not in PATH\n" >&2
    exit 1
fi

pandoc_args=(-f markdown -t org --wrap=preserve)

if [[ -n "${input}" ]]; then
    if [[ ! -f "${input}" ]]; then
        printf "error: input file not found: %s\n" "${input}" >&2
        exit 1
    fi
    pandoc_args+=("${input}")
fi

if [[ -n "${output}" ]]; then
    pandoc_args+=(-o "${output}")
fi

pandoc "${pandoc_args[@]}"
