# emacsclient_tty - run `emacsclient -nw -c` on the *concrete* controlling
# terminal so it is safe to use as $EDITOR for pipe editors like vipe(1).
#
# Why this exists:
#   Tools such as vipe reopen the editor's stdin/stdout on /dev/tty before
#   launching $EDITOR. `emacsclient -nw` resolves the terminal name with
#   ttyname(STDOUT_FILENO) and forwards that *name* to the Emacs daemon,
#   asking the daemon to open it. A descriptor opened on /dev/tty resolves
#   back to the literal "/dev/tty" (device 5,0), which only ever means "my
#   controlling terminal" -- and the daemon has none. The daemon's open()
#   then fails with:  *ERROR*: Could not open file: /dev/tty
#
#   Resolving the concrete pts (e.g. /dev/pts/3) from the kernel and pointing
#   emacsclient's stdin/stdout at it removes the ambiguity: the daemon can
#   open /dev/pts/3 just fine, and we keep the daemon's instant start-up.

set -euo pipefail

# resolve_tty: print the concrete controlling terminal (e.g. /dev/pts/3) on
# stdout, or return non-zero when there is not a usable one.
resolve_tty() {
    local t
    # ps reads the controlling terminal from the kernel, so it yields the
    # real pts even when our own stdin/stdout were redirected to /dev/tty.
    t="$(ps -o tty= -p "$$" 2>/dev/null | tr -d '[:space:]')" || true
    if [[ -n "${t}" && "${t}" != "?" && -c "/dev/${t}" ]]
    then
        printf '/dev/%s' "${t}"
        return 0
    fi
    return 1
}

if tty_dev="$(resolve_tty)"
then
    exec emacsclient -nw -c "$@" <"${tty_dev}" >"${tty_dev}"
fi

# No usable controlling terminal (e.g. invoked non-interactively): fall back
# to a standalone `emacs -nw`, which opens whatever terminal it inherits from
# its own process rather than delegating to the daemon.
exec emacs -nw "$@"
